// Shared pixel-based clustering: groups sages by shared city, then fans
// them out around that point in screen-pixel space (not geographic
// degrees), so spacing stays visually consistent at any zoom level.
// A deliberately small radius is used so dots at the same city sit close
// enough to slightly overlap rather than fully separate — keeping a tight
// cluster that still lets each dot be individually hovered.
// Groups sages by actual screen-pixel proximity (not by exact-matching
// rounded lat/lng), then fans each cluster out around its average center
// in pixel space. This is more robust than exact-coordinate grouping:
// several sages can be placed at "the same city" with slightly different
// hand-entered coordinates (e.g. Tiberias stored as 32.791,35.536 for one
// sage and 32.794,35.531 for another) and still end up correctly grouped
// together here, since what matters is whether their dots would visually
// overlap on screen — not whether their raw coordinates match exactly.
function computePixelClusteredPositions(rabbisList, dotSizePx){
  if(rabbisList.length===0) return {};

  // Pixel position of every sage at the CURRENT view
  const pixelPos=rabbisList.map(r=>({
    r, pt:gmap.latLngToContainerPoint([r.lat,r.lng])
  }));

  // Union-find style clustering: anyone within this many pixels of any
  // other member of a cluster joins that cluster (so clusters can span
  // a chain of nearby points, not just exact pairs).
  const proximityThresholdPx=dotSizePx*0.9;
  const clusters=[]; // each: array of {r,pt}
  pixelPos.forEach(item=>{
    let joined=null;
    for(const cluster of clusters){
      if(cluster.some(other=>Math.hypot(other.pt.x-item.pt.x, other.pt.y-item.pt.y)<proximityThresholdPx)){
        joined=cluster;
        break;
      }
    }
    if(joined) joined.push(item);
    else clusters.push([item]);
  });

  const posById={};
  clusters.forEach(cluster=>{
    const n=cluster.length;
    if(n===1){
      posById[cluster[0].r.id]=[cluster[0].r.lat,cluster[0].r.lng];
      return;
    }
    // Average pixel center of the whole cluster, so the fan-out is
    // centered on the group rather than biased toward whichever sage
    // happened to be first.
    const cx=cluster.reduce((s,it)=>s+it.pt.x,0)/n;
    const cy=cluster.reduce((s,it)=>s+it.pt.y,0)/n;
    // Radius is deliberately small relative to the dot size: for n=2 the
    // two dots land 2*radiusPx apart, so keeping radiusPx well under the
    // dot's own radius (dotSizePx/2) makes them visibly overlap rather
    // than sit fully separate, while still being distinguishable enough
    // to hover individually.
    const radiusPx=Math.max(4, dotSizePx*0.3 + n*1.2);
    cluster.forEach((item,i)=>{
      const angle=(i/n)*2*Math.PI - Math.PI/2;
      const px=L.point(cx+Math.cos(angle)*radiusPx, cy+Math.sin(angle)*radiusPx);
      const ll=gmap.containerPointToLatLng(px);
      posById[item.r.id]=[ll.lat,ll.lng];
    });
  });
  return posById;
}

function computeOffsets(aliveList){
  const positions=computePixelClusteredPositions(aliveList, 22);
  const posById={};
  Object.keys(positions).forEach(id=>{
    posById[id]={lat:positions[id][0], lng:positions[id][1]};
  });
  return posById;
}

