  {id:"rybz",         name:"ריב\"ז",              type:"tan",gen:"דור א׳",born:null,died:null, lat:31.876,lng:34.745,city:"יבנה",           role:"מייסד יבנה",            isL:true, desc:"מייסד המרכז התורני ביבנה לאחר חורבן הבית. ניהל משא ומתן עם אספסיאנוס. הציל את התורה לדורות."},
  {id:"rg_yavne",     name:"רבן גמליאל דיבנה",  type:"tan",gen:"דור ב׳",born:null,died:null,lat:31.880,lng:34.750,city:"יבנה",           role:"נשיא יבנה",             isL:true, desc:"נשיא הסנהדרין ביבנה. איחד את עם ישראל לאחר החורבן. הוסיף 'ולמלשינים' לסדר התפילה."},
