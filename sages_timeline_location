  {id:"ryehoshua",    name:"ר' יהושע",          type:"tan",gen:"דור ב׳",born:null,died:null,lat:31.874,lng:34.755,city:"יבנה",           role:"תנא, מתון ופייסן",      isL:false,desc:"מגדולי תנאי יבנה. ידוע בגישתו המתונה. ניהל ויכוחים עם קיסרים ופילוסופים."},
