    item.className='gen-legend-item';
    item.innerHTML='<div class="gen-legend-dot" style="background:'+color+'"></div>'+
      (r.type==='tan'?'תנאים ':'אמוראים ')+r.gen;
    legend.appendChild(item);
  });
}

// Builds a chart showing ONLY the sages cited on the selected daf, grouped
// by generation exactly like the full chart, but filtered to just them.
function buildDafChart(citedRabbis){
  const scroll=document.getElementById('chartscroll');
  scroll.innerHTML='';

  const header=document.createElement('div');
  header.style.cssText='font-size:12px;color:#8A7A60;margin-bottom:10px;line-height:1.5';
  header.textContent='מציג רק את החכמים המוזכרים בעמוד זה.';
  scroll.appendChild(header);

  function renderPeriod(type,label,genOrder,genYears){
    const inType=citedRabbis.filter(r=>r.type===type);
    if(inType.length===0) return;
    const periodLbl=document.createElement('div');
    periodLbl.className='chart-period-label '+type;
    periodLbl.textContent=label;
    scroll.appendChild(periodLbl);

    genOrder.forEach(gen=>{
      const inGen=inType.filter(r=>r.gen===gen);
      if(inGen.length===0) return;
      const genDiv=document.createElement('div');
      genDiv.className='chart-gen';
      const hdr=document.createElement('div');
      hdr.className='chart-gen-hdr '+type;
      hdr.style.background=genColor(inGen[0]);
      hdr.style.color='#fff';
      hdr.innerHTML='<span>'+gen+'</span><span class="chart-gen-years">'+genYears[gen]+' לסה</span>';
      genDiv.appendChild(hdr);
      inGen.forEach(r=>{
        const row=document.createElement('div');
        row.className='chart-rabbi';
        row.dataset.rabbiId=r.id;
        const yearsLabel=formatLifeRange(r);
        row.innerHTML='<span class="chart-rabbi-name">'+r.name+'</span><span class="chart-rabbi-years">'+yearsLabel+'</span>';
        row.onmouseenter=()=>showInfo(r);
        row.onmouseleave=()=>hideInfo();
        row.onclick=()=>highlightDafSageOnMap(r.id);
        genDiv.appendChild(row);
      });
      scroll.appendChild(genDiv);
    });
  }

  renderPeriod('tan','תנאים',GEN_ORDER_TAN,GEN_YEARS_TAN);
  renderPeriod('amo','אמוראים',GEN_ORDER_AMO,GEN_YEARS_AMO);
}

// Fixed view used every time daf mode is entered, so the map always looks
// the same regardless of which sages happen to be cited — covering both
// the Land of Israel and Babylonia at once. You can still zoom/pan freely
// afterward; this is just the starting point.
const DAF_MODE_CENTER=[32.4,40.0];
const DAF_MODE_ZOOM=6;

// Offsets overlapping/near-overlapping dots in SCREEN PIXELS rather than
// geographic degrees, so sages from the same or nearby cities stay visibly
// separated even when the map is zoomed out (a fixed degree-offset becomes
// invisible at low zoom, since each pixel covers many more real-world km).
// Uses the same shared clustering helper as normal mode, with the same
// 24px daf-dot size, so spacing/overlap behavior is consistent everywhere.
function computePixelOffsetPositions(rabbisList){
  return computePixelClusteredPositions(rabbisList, 24);
}

let currentDafCitedRabbis=[]; // remembered so dots can be re-clustered on zoom/pan

function redrawDafDots(){
  if(!dafModeActive) return;
  const positions=computePixelOffsetPositions(currentDafCitedRabbis);
  dafSageMarkers.forEach(m=>{
    const pos=positions[m._rabbiId];
    if(pos) m.setLatLng(pos);
  });
}

// Clicking a sage's row in the (filtered) daf chart highlights their dot
// on the map: clears any previous selection, marks this one with a gold
// ring + slight pop via the .selected CSS class, and pins the info panel
// open (independent of hover, so it stays visible while you look at the map).
let selectedDafSageId=null;

function toggleDafSageHighlight(rabbiId){
  if(selectedDafSageId===rabbiId){
    // Clicking the already-selected sage again clears the selection
    document.querySelectorAll('.daf-sage-dot.selected').forEach(el=>el.classList.remove('selected'));
    document.querySelectorAll('.chart-rabbi.selected').forEach(el=>el.classList.remove('selected'));
    selectedDafSageId=null;
    return;
  }
  document.querySelectorAll('.daf-sage-dot.selected').forEach(el=>el.classList.remove('selected'));
  document.querySelectorAll('.chart-rabbi.selected').forEach(el=>el.classList.remove('selected'));

  const marker=dafSageMarkers.find(m=>m._rabbiId===rabbiId);
  if(marker && marker._icon){
    const dot=marker._icon.querySelector('.daf-sage-dot');
    if(dot) dot.classList.add('selected');
  }
  const row=document.querySelector('.chart-rabbi[data-rabbi-id="'+rabbiId+'"]');
  if(row) row.classList.add('selected');

  const r=RABBIS.find(x=>x.id===rabbiId);
  if(r) showInfo(r);
  selectedDafSageId=rabbiId;

  // Pan the map to this sage's dot (keeping the current zoom level rather
  // than forcing it back to the fixed overview) — this only happens when
  // picking a sage from the chart while already in daf mode; the fixed
  // overview is restored separately whenever a daf is freshly selected or
  // daf mode is entered from map mode.
  if(marker){
    gmap.panTo(marker.getLatLng());
  }
}
// Kept as an alias since existing chart-row click handlers call this name
function highlightDafSageOnMap(rabbiId){ toggleDafSageHighlight(rabbiId); }

function applyDafSelection(dafId){
  // Clear any pulse ring left over from normal map mode (or a previous
  // daf selection) before doing anything else, so it never lingers when
  // switching between modes or between different dapim.
  clearMapPulse();

  const entry=CHULLIN_DAFIM.find(d=>d.daf===dafId);
  document.getElementById('dafclear').style.display = dafId ? 'inline-block' : 'none';

  if(!dafId){
    clearDafMode();
    document.getElementById('dafverified').style.display='none';
    document.getElementById('dafunverified').style.display='none';
    document.getElementById('gen-legend').innerHTML='';
    return;
  }

  if(!entry || entry.sages.length===0){
    clearDafMode();
    document.getElementById('dafverified').style.display='none';
    document.getElementById('dafunverified').style.display='inline';
    document.getElementById('gen-legend').innerHTML='';
    return;
  }

  document.getElementById('dafverified').style.display='inline';
  document.getElementById('dafverified').textContent='✓ מאומת — חכמים אמיתיים מהדף';
  document.getElementById('dafunverified').style.display='none';

  const citedRabbis=entry.sages.map(id=>RABBIS.find(r=>r.id===id)).filter(Boolean);
  buildGenLegend(citedRabbis);
  currentDafCitedRabbis=citedRabbis;

  // Enter daf mode: remove all normal markers, show only small dots for
  // exactly the cited sages, regardless of the timeline year — these sages
  // are being shown because the TEXT cites them, not because of when they
  // lived, so the year slider is irrelevant while a daf is selected.
  dafModeActive=true;
  currentAliveIds.forEach(id=>{
    if(rabbiMarkerById[id]){ gmap.removeLayer(rabbiMarkerById[id]); delete rabbiMarkerById[id]; }
  });
  currentAliveIds=new Set();
  dafSageMarkers.forEach(m=>{ try{ gmap.removeLayer(m); }catch(e){} });
  dafSageMarkers.length=0;

  // Always reset to the same fixed view first, so the map looks identical
  // every time you pick a daf — Israel and Babylonia both in frame, every
  // time — rather than zooming to fit whichever sages happen to be cited.
  gmap.setView(DAF_MODE_CENTER, DAF_MODE_ZOOM);

  const positions=computePixelOffsetPositions(citedRabbis);
  citedRabbis.forEach(r=>{
    const color=genColor(r);
    const pos=positions[r.id] || [r.lat,r.lng];
    const marker=L.marker(pos,{
      icon:L.divIcon({
        className:'',
        html:'<div class="daf-sage-dot" data-rabbi-id="'+r.id+'" style="background:'+color+'"></div>',
        iconSize:[24,24],
        iconAnchor:[12,12]
      }),
      zIndexOffset:200,
      title:r.name
    });
    marker._rabbiId=r.id;
    marker.on('mouseover',()=>showInfo(r));
    marker.on('mouseout',()=>hideInfo());
    marker.on('click',()=>toggleDafSageHighlight(r.id));
    marker.addTo(gmap);
    dafSageMarkers.push(marker);
  });

  // Keep dots correctly separated if the person zooms/pans afterward —
  // pixel-based offsets need recomputing whenever the projection changes.
  // (off() before on() keeps this idempotent if a daf is picked repeatedly
  // without clearing in between, so the handler never stacks duplicates.)
  gmap.off('zoomend',redrawDafDots);
  gmap.off('moveend',redrawDafDots);
  gmap.on('zoomend',redrawDafDots);
  gmap.on('moveend',redrawDafDots);

  // Replace the chart with a version showing only these sages
  buildDafChart(citedRabbis);
  openChart();
}

dafSelect.addEventListener('change',()=>applyDafSelection(dafSelect.value));
document.getElementById('dafclear').onclick=()=>{
  dafSelect.value='';
  applyDafSelection('');
};

function openChart(){
  document.getElementById('chartpanel').classList.add('open');
  document.getElementById('chartbtn').classList.add('active');
}
function closeChart(){
  document.getElementById('chartpanel').classList.remove('open');
  document.getElementById('chartbtn').classList.remove('active');
}
document.getElementById('chartbtn').onclick=()=>{
  const panel=document.getElementById('chartpanel');
  if(panel.classList.contains('open')) closeChart(); else openChart();
};
document.getElementById('chartclose').onclick=closeChart;

function highlightInChart(rabbiId){
  document.querySelectorAll('.chart-rabbi.highlight').forEach(el=>el.classList.remove('highlight'));
  const row=document.querySelector('.chart-rabbi[data-rabbi-id="'+rabbiId+'"]');
  if(row){
    row.classList.add('highlight');
    row.scrollIntoView({behavior:'smooth',block:'center'});
  }
}

// ══════════════════════════════════════
// PULSE RING — implemented as a normal Leaflet marker with a divIcon,
// so it automatically tracks pan/zoom with zero custom projection code.
// ══════════════════════════════════════
let pulseMarker=null;
let pulsedRabbiId=null; // which sage's marker is currently pulsing, if any

function showMapPulse(latlng){
  clearMapPulse();
  if(!latlng) return;
  pulseMarker=L.marker(latlng,{
    icon:L.divIcon({className:'',html:'<div class="map-pulse-ring"></div>',iconSize:[46,46],iconAnchor:[23,23]}),
    interactive:false,
    zIndexOffset:1000
  }).addTo(gmap);
}
function clearMapPulse(){
  if(pulseMarker){ gmap.removeLayer(pulseMarker); pulseMarker=null; }
  pulsedRabbiId=null;
  document.querySelectorAll('.chart-rabbi.highlight').forEach(el=>el.classList.remove('highlight'));
}

// Clicking a sage's marker on the map (normal mode): if it's already the
// one pulsing, clicking it again clears the pulse AND closes the chart
// (full toggle-off); otherwise it pulses this sage, opens the chart, and
// highlights their row there.
function toggleMapPulse(r, latlng){
  if(pulsedRabbiId===r.id){
    clearMapPulse();
    closeChart();
    return;
  }
  showMapPulse(latlng);
  pulsedRabbiId=r.id;
  openChart();
  highlightInChart(r.id);
}

// Called when clicking a rabbi's row inside the chart
function jumpToRabbi(r){
  const {born:lifeBorn, died:lifeDied} = getLifeRange(r);
  const targetYear=Math.max(START, Math.min(END, Math.round((lifeBorn+lifeDied)/2)));
  slider.value=targetYear;
  render(targetYear);

  gmap.flyTo([r.lat,r.lng], Math.max(gmap.getZoom(),7), {duration:0.6});

  const marker=rabbiMarkerById[r.id];
  showMapPulse(marker ? marker.getLatLng() : [r.lat,r.lng]);

  showInfo(r);
  openChart();
  highlightInChart(r.id);
}

function render(year){
  document.getElementById('ydisplay').textContent=year;
  updateFill();

  const alive=RABBIS.filter(r=>{
    const {born,died}=getLifeRange(r);
    return year>=born && year<=died;
  });
  const aliveIds=new Set(alive.map(r=>r.id));

  const tc=alive.filter(r=>r.type==='tan').length;
  const ac=alive.filter(r=>r.type==='amo').length;
  const parts=[];
  if(tc)parts.push(tc+' תנאים');
  if(ac)parts.push(ac+' אמוראים');
  document.getElementById('cbadge').textContent=parts.join(' · ')||'אין חכמים';

  const gensList=year<220?[
    [10,80,"דור א׳ תנאים"],[80,120,"דור ב׳ תנאים"],[120,160,"דור ג׳ תנאים"],
    [160,200,"דור ד׳ תנאים"],[200,220,"דור ה׳ תנאים"]
  ]:[
    [220,250,"דור א׳ אמוראים"],[250,290,"דור ב׳ אמוראים"],[290,320,"דור ג׳ אמוראים"],
    [320,370,"דור ד׳ אמוראים"],[370,420,"דור ה׳ אמוראים"],[420,500,"דור ו׳ — סבוראים"]
  ];
  const g=gensList.find(([s,e])=>year>=s&&year<e);
  document.getElementById('plabel').textContent=g?g[2]:'';

  // In daf mode, only the cited sages are shown (as small dots, handled by
  // renderDafMode); the normal year-driven marker rendering is suspended so
  // the two display modes never fight over the same markers.
  if(dafModeActive) return;

  const positions=computeOffsets(alive);

  currentAliveIds.forEach(id=>{
    if(!aliveIds.has(id)){
      if(rabbiMarkerById[id]){
        gmap.removeLayer(rabbiMarkerById[id]);
        delete rabbiMarkerById[id];
      }
    }
  });

  alive.forEach(r=>{
    const pos=positions[r.id];
    if(rabbiMarkerById[r.id]){
      rabbiMarkerById[r.id].setLatLng(pos);
    } else {
      const marker=L.marker(pos,{
        icon:makeRabbiDivIcon(r),
        zIndexOffset: r.isL?100:50,
        title:r.name
      });
      marker.on('mouseover',()=>showInfo(r));
      marker.on('mouseout',()=>hideInfo());
      marker.on('click',()=>toggleMapPulse(r, marker.getLatLng()));
      marker.addTo(gmap);
      rabbiMarkerById[r.id]=marker;
    }
  });

  currentAliveIds=aliveIds;
  lastAliveList=alive;
}

// Recompute pixel-clustered positions for the currently-shown normal-mode
// markers whenever the map is zoomed or panned (same reasoning as daf
// mode's redrawDafDots: pixel-based offsets must be re-derived whenever
// the projection changes, or dots from the same city would drift apart
// or back together incorrectly as you zoom).
let lastAliveList=[];
function redrawNormalDots(){
  if(dafModeActive || lastAliveList.length===0) return;
  const positions=computeOffsets(lastAliveList);
  lastAliveList.forEach(r=>{
    const pos=positions[r.id];
    if(pos && rabbiMarkerById[r.id]) rabbiMarkerById[r.id].setLatLng(pos);
  });
}
gmap.on('zoomend',redrawNormalDots);
gmap.on('moveend',redrawNormalDots);

// ── Info panel (hover-driven: appears on mouseover, disappears on mouseout) ──
function showInfo(r){
  document.getElementById('iname').textContent=r.name;
  const b=document.getElementById('ibadge');
  b.textContent=(r.type==='tan'?'תנא':'אמורא')+' · '+r.gen;
  b.className=r.type;
  document.getElementById('iyears').textContent=formatLifeRange(r)+' לסה';
  document.getElementById('irole').textContent=r.role;
  document.getElementById('icitytxt').textContent=r.city;
  document.getElementById('idesc').textContent=r.desc;
  document.getElementById('info').classList.add('on');
}
function hideInfo(){
  document.getElementById('info').classList.remove('on');
}

slider.addEventListener('input',()=>render(parseInt(slider.value)));

let playing=false,ptimer=null;
document.getElementById('playbtn').onclick=()=>{
  playing=!playing;
  document.getElementById('playbtn').textContent=playing?'⏸':'▶';
  if(playing){
    let v=parseInt(slider.value); if(v>=END){v=START;slider.value=START;}
    ptimer=setInterval(()=>{v+=2;if(v>END){v=END;playing=false;clearInterval(ptimer);document.getElementById('playbtn').textContent='▶';}slider.value=v;render(v);},60);
  } else clearInterval(ptimer);
};

render(50);

// ══════════════════════════════════════
// PRINT — builds a clean two-column single-page reference table
// of every Tanna/Amora and triggers the browser print dialog.
// ══════════════════════════════════════
function buildPrintChart(){
  const root=document.getElementById('printchart');
  root.innerHTML='';

  const title=document.createElement('h1');
  title.textContent='תנאים ואמוראים — לוח ייחוס';
  root.appendChild(title);
  const sub=document.createElement('div');
  sub.className='print-sub';
  sub.textContent='ציר הזמן המלא · 10–500 לספירה';
  root.appendChild(sub);

  const cols=document.createElement('div');
  cols.className='print-cols';
  root.appendChild(cols);

  function buildColumn(type,label,genOrder,genYears){
    const col=document.createElement('div');
    col.className='print-col';
    const lbl=document.createElement('div');
    lbl.className='print-period';
    lbl.textContent=label;
    col.appendChild(lbl);

    genOrder.forEach(gen=>{
      const inGen=RABBIS.filter(r=>r.type===type && r.gen===gen);
      if(inGen.length===0) return;
      const genDiv=document.createElement('div');
      genDiv.className='print-gen';
      const hdr=document.createElement('div');
      hdr.className='print-gen-hdr';
      hdr.innerHTML='<span>'+gen+'</span><span>'+genYears[gen]+' לסה</span>';
      genDiv.appendChild(hdr);
      inGen.forEach(r=>{
        const yearsLabel=formatLifeRange(r);
        const row=document.createElement('div');
        row.className='print-rabbi';
        row.innerHTML=
          '<span class="print-rabbi-name">'+r.name+'</span>'+
          '<span class="print-rabbi-role">'+r.role+'</span>'+
          '<span class="print-rabbi-years">'+yearsLabel+'</span>';
        genDiv.appendChild(row);
      });
      col.appendChild(genDiv);
    });
    return col;
  }

  cols.appendChild(buildColumn('tan','תנאים',GEN_ORDER_TAN,GEN_YEARS_TAN));
  cols.appendChild(buildColumn('amo','אמוראים',GEN_ORDER_AMO,GEN_YEARS_AMO));
}

document.getElementById('printbtn').onclick=()=>{
  buildPrintChart();
  window.print();
};
</script>
