// ══════════════════════════════════════
// DATE HANDLING — honesty note:
// Exact birth/death years are not historically documented for Tannaim and
// Amoraim; ancient rabbinic sources essentially never record them. Rather
// than inventing or implying personal lifespans, every individual displays
// only their generation's approximate, scholarly-accepted date range (per
// standard rabbinic chronology, e.g. Encyclopaedia Judaica / Heinrich
// Graetz periodization).
// ══════════════════════════════════════
const GEN_RANGE_TAN={"דור א׳":[10,80],"דור ב׳":[80,120],"דור ג׳":[120,160],"דור ד׳":[160,200],"דור ה׳":[200,220]};
const GEN_RANGE_AMO={"דור א׳":[220,250],"דור ב׳":[250,290],"דור ג׳":[290,320],"דור ד׳":[320,370],"דור ה׳":[370,420],"דור ו׳":[420,500]};

function getLifeRange(r){
  const table = r.type==='tan' ? GEN_RANGE_TAN : GEN_RANGE_AMO;
  const [genStart,genEnd] = table[r.gen] || [START,END];
  return {born:genStart, died:genEnd};
}

// Formats a sage's generation range for display, always marked "~" to make
// clear these are generation-level approximations, not personal dates.
function formatLifeRange(r){
  const {born, died} = getLifeRange(r);
  const bstr = '~' + (born<0 ? Math.abs(born)+' לפנה"ס' : String(born));
  const dstr = '~' + String(died);
  return bstr+'–'+dstr;
}


