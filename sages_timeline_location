// Basemap with automatic fallback across multiple independent tile providers.
// Honesty note on why this exists: we tried committing to a single "best"
// provider three times in a row (CARTO Voyager, then OpenStreetMap directly,
// then Esri World Street Map) and each had a real, separately-discovered
// problem — inconsistent/conflicting documented URLs, an active Referer
// header requirement that breaks local file:// pages, and an ambiguous
// "legacy/mature support" deprecation status, respectively. Rather than
// guess at a fourth "definitely correct" single source, this tries several
// real, independent providers in order and keeps whichever one actually
// succeeds at loading tiles in your specific browser/network — so the map
// works even if any one provider is unavailable, slow, or blocking this
// particular request pattern.
const TILE_PROVIDERS=[
  {
    name:'Esri World Street Map',
    url:'https://server.arcgisonline.com/ArcGIS/rest/services/World_Street_Map/MapServer/tile/{z}/{y}/{x}',
    options:{maxZoom:19,attribution:'Tiles &copy; Esri &mdash; Source: Esri, DeLorme, NAVTEQ'}
  },
  {
    name:'Esri World Topo Map',
    url:'https://server.arcgisonline.com/ArcGIS/rest/services/World_Topo_Map/MapServer/tile/{z}/{y}/{x}',
    options:{maxZoom:19,attribution:'Tiles &copy; Esri &mdash; Source: Esri, DeLorme, NAVTEQ'}
  },
  {
    name:'CARTO Voyager',
    url:'https://tiles.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}.png',
    options:{maxZoom:20,attribution:'&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a> contributors, &copy; <a href="https://carto.com/attributions" target="_blank">CARTO</a>'}
  },
  {
    name:'OpenStreetMap',
    url:'https://tile.openstreetmap.org/{z}/{x}/{y}.png',
    options:{maxZoom:19,attribution:'&copy; <a href="https://www.openstreetmap.org/copyright" target="_blank">OpenStreetMap</a> contributors'}
  }
];

let activeTileLayer=null;
let providerIndex=0;
let successfulTileCount=0;

function tryNextTileProvider(){
  if(providerIndex>=TILE_PROVIDERS.length){
    console.error('All tile providers failed to load.');
    document.getElementById('map').insertAdjacentHTML('beforeend',
      '<div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:#fee;color:#700;padding:20px;border-radius:8px;font-family:sans-serif;text-align:center;max-width:80%;direction:ltr">'+
      'Could not load any map tile provider. Check your internet connection.'+
      '</div>');
    return;
  }
  const provider=TILE_PROVIDERS[providerIndex];
  successfulTileCount=0;
  if(activeTileLayer){ gmap.removeLayer(activeTileLayer); }
  activeTileLayer=L.tileLayer(provider.url, provider.options);
  activeTileLayer.on('tileload', function(){
    successfulTileCount++;
  });
  activeTileLayer.on('tileerror', function(){
    // If we haven't yet seen ANY successful tile from this provider after a
    // burst of errors, assume the whole provider is unreachable and move on.
    if(successfulTileCount===0){
      providerIndex++;
      setTimeout(tryNextTileProvider, 50);
    }
  });
  activeTileLayer.addTo(gmap);
  console.log('Trying tile provider:', provider.name);
}
tryNextTileProvider();

