<!DOCTYPE html>
<html lang="he">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>מפת התנאים והאמוראים — OpenStreetMap</title>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
<script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+Hebrew:wght@400;600;700;900&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --gold:#C8860A;--gold-dk:#8B5E0A;--gold-pale:#FEF3C7;
  --blue:#2563EB;--blue-dk:#1E3A6A;--blue-pale:#DBEAFE;
  --ink:#1A1208;
}
html,body{height:100%;font-family:'Noto Serif Hebrew',serif;overflow:hidden;background:#1a1208;direction:rtl}
#app{display:flex;flex-direction:column;height:100vh}

/* Header */
#hdr{background:var(--ink);padding:7px 16px;display:flex;align-items:center;justify-content:space-between;border-bottom:2px solid var(--gold-dk);flex-shrink:0}
#htitle{font-size:17px;font-weight:900;color:var(--gold)}
#hsub{font-size:10px;color:#B8A880;margin-top:1px}
.lpills{display:flex;gap:12px;align-items:center}
.lpill{display:flex;align-items:center;gap:5px;font-size:11px;color:#C8B890}
.ldot{width:11px;height:11px;border-radius:50%;flex-shrink:0}
#chartbtn,#printbtn{
  background:rgba(200,134,10,.15);border:1px solid var(--gold-dk);border-radius:6px;
  color:var(--gold);font-size:14px;padding:3px 10px;cursor:pointer;line-height:1;
}
#chartbtn:hover,#printbtn:hover{background:rgba(200,134,10,.3)}
#chartbtn.active{background:var(--gold-dk);color:#1A1208}

/* Timeline */
#tpanel{background:var(--ink);border-bottom:2px solid var(--gold-dk);padding:8px 16px 11px;flex-shrink:0}

/* Masechet Chullin daf selector panel */
#dafpanel{
  background:#241608;border-bottom:2px solid var(--gold-dk);
  padding:8px 16px;display:flex;align-items:center;gap:10px;flex-wrap:wrap;flex-shrink:0;
}
#dafpanel-label{font-size:13px;font-weight:700;color:var(--gold)}
#dafselect{
  background:#FDF6E3;border:1.5px solid var(--gold-dk);border-radius:6px;
  padding:5px 10px;font-size:13px;font-family:'Noto Serif Hebrew',serif;color:var(--ink);
  cursor:pointer;direction:rtl;
}
#dafverified{font-size:11px;color:#8FE89A;font-weight:700}
#dafunverified{font-size:11px;color:#F0C060;font-weight:700}
#dafclear{
  background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.2);border-radius:6px;
  color:#C8B890;font-size:11px;padding:3px 9px;cursor:pointer;
}
#dafclear:hover{background:rgba(255,255,255,.18)}
#gen-legend{display:flex;gap:8px;flex-wrap:wrap;margin-right:auto}
.gen-legend-item{display:flex;align-items:center;gap:4px;font-size:10.5px;color:#C8B890;white-space:nowrap}
.gen-legend-dot{width:11px;height:11px;border-radius:50%;flex-shrink:0;border:1.5px solid rgba(255,255,255,.4)}

#ttop{display:flex;align-items:center;gap:12px;margin-bottom:8px}
#ydisplay{font-size:26px;font-weight:900;color:var(--gold);min-width:66px;text-align:center;line-height:1}
#ylabel{font-size:10px;color:#8A7A60;text-align:center}
#playbtn{width:32px;height:32px;border-radius:50%;border:2px solid var(--gold-dk);background:transparent;color:var(--gold);font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0}
#cbadge{background:rgba(200,134,10,.12);border:1px solid var(--gold-dk);border-radius:20px;padding:3px 11px;font-size:12px;color:var(--gold);white-space:nowrap}
#plabel{font-size:11px;font-weight:700;color:var(--gold);margin-right:auto}

#ttrack{direction:ltr}
#pbars{position:relative;height:17px;margin-bottom:5px;border-radius:4px;background:rgba(255,255,255,.05);overflow:hidden}
.pbar{position:absolute;top:0;bottom:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;letter-spacing:1px}
.pbar.tan{background:linear-gradient(90deg,rgba(139,94,10,.78),rgba(200,134,10,.78));color:#FEF3C7}
.pbar.amo{background:linear-gradient(90deg,rgba(30,58,106,.78),rgba(37,99,235,.78));color:#DBEAFE}
.gdiv{position:absolute;top:0;bottom:0;width:1px;background:rgba(255,255,255,.22)}
#swrap{position:relative;height:22px;display:flex;align-items:center}
#sbg{position:absolute;left:0;right:0;height:6px;background:rgba(255,255,255,.1);border-radius:3px}
#sfill{position:absolute;left:0;height:6px;background:linear-gradient(90deg,var(--gold-dk),var(--gold));border-radius:3px;pointer-events:none;transition:width .05s}
#slider{position:relative;z-index:2;width:100%;background:transparent;outline:none;cursor:pointer;height:22px;-webkit-appearance:none;appearance:none}
#slider::-webkit-slider-thumb{-webkit-appearance:none;width:20px;height:20px;border-radius:50%;background:var(--gold);border:3px solid #1A1208;box-shadow:0 0 10px rgba(200,134,10,.7);cursor:grab}
#slider::-moz-range-thumb{width:20px;height:20px;border-radius:50%;background:var(--gold);border:3px solid #1A1208;cursor:grab;border:none}
#yticks{position:relative;height:14px;margin-top:3px}
.tlbl{position:absolute;transform:translateX(-50%);font-size:9.5px;color:#6A5A40;font-family:sans-serif;white-space:nowrap}
.tlbl.maj{color:#9A8A60;font-weight:700}

/* Map */
#mapwrap{flex:1;position:relative}
#map{width:100%;height:100%;background:#cfe0b8}
.leaflet-control-attribution{font-size:10px}

/* Info panel — compact, bottom-right, shown on hover */
#info{
  position:absolute;bottom:20px;right:20px;left:auto;
  transform:translateY(10px) scale(0.94);
  width:300px;max-width:80vw;
  background:rgba(253,246,227,.98);border-radius:12px;border:2px solid var(--gold-dk);
  box-shadow:0 10px 32px rgba(0,0,0,.5);z-index:500;display:none;direction:rtl;overflow:hidden;
  opacity:0;pointer-events:none;
  transition:opacity .15s ease, transform .15s cubic-bezier(.34,1.56,.64,1);
}
#info.on{display:block;opacity:1;transform:translateY(0) scale(1)}
#ihdr{padding:12px 14px 9px;border-bottom:1.5px solid rgba(200,134,10,.3);display:flex;justify-content:space-between;align-items:flex-start}
#iname{font-size:18px;font-weight:900;color:var(--ink);line-height:1.15}
#ibadge{font-size:10.5px;font-weight:700;padding:2px 9px;border-radius:10px;display:inline-block;margin-top:5px}
#ibadge.tan{background:var(--gold-pale);color:var(--gold-dk)}
#ibadge.amo{background:var(--blue-pale);color:var(--blue-dk)}
#iclose{display:none}
#ibody{padding:10px 14px 13px}
.irow{display:flex;gap:14px;margin-bottom:9px}
.ifield{flex:1}
.ilbl{font-size:10px;color:#8A7A60;margin-bottom:2px;font-weight:600}
.ival{font-size:13px;font-weight:800;color:var(--ink)}
#icity{display:inline-flex;align-items:center;gap:5px;background:#FEF9ED;border:1px solid var(--gold-dk);border-radius:18px;padding:3px 10px;font-size:11px;font-weight:700;color:var(--gold-dk);margin-bottom:9px}
#idesc{font-size:12px;color:#2A1A08;line-height:1.5;border-top:1.5px solid rgba(200,134,10,.22);padding-top:9px}

/* City markers via divIcon */
.city-marker-dot{
  width:18px;height:18px;border-radius:50%;background:#C8860A;
  border:2.5px solid #FFF6DC;box-shadow:0 1px 5px rgba(0,0,0,.4);
}
.city-marker-label{
  font-family:'Noto Serif Hebrew',serif;font-weight:800;font-size:16px;color:#2A1A00;
  white-space:nowrap;text-shadow:
    -1.5px -1.5px 0 #FFF6DC, 1.5px -1.5px 0 #FFF6DC,
    -1.5px 1.5px 0 #FFF6DC, 1.5px 1.5px 0 #FFF6DC,
    0 0 6px #FFF6DC;
  pointer-events:none;
}

/* Rabbi markers — small dots colored by generation, used everywhere on
   the map (both the normal year-driven view and the daf-citation view),
   so the whole map uses one consistent, uncluttered visual language. */
.rabbi-dot, .daf-sage-dot{
  width:22px;height:22px;border-radius:50%;
  border:2.5px solid rgba(255,255,255,.95);
  box-shadow:0 2px 7px rgba(0,0,0,.55);
  cursor:pointer;
}
.rabbi-dot.lead, .daf-sage-dot.lead{
  border-color:#FFD700;border-width:3px;
  box-shadow:0 0 8px rgba(255,215,0,.55), 0 2px 7px rgba(0,0,0,.55);
}
.daf-sage-dot.selected{
  border-color:#FFD700;border-width:3.5px;
  box-shadow:0 0 0 4px rgba(255,215,0,.5), 0 2px 7px rgba(0,0,0,.6);
  transform:scale(1.25);
}

/* Pulse ring (Leaflet divIcon, positioned via L.marker so it tracks pan/zoom automatically) */
.map-pulse-ring{
  width:46px;height:46px;border-radius:50%;border:3px solid #FFD700;
  animation:pulseRing 1.3s ease-out infinite;pointer-events:none;
}
@keyframes pulseRing{
  0%{transform:scale(0.5);opacity:1}
  100%{transform:scale(2.2);opacity:0}
}

/* ══════════════════════════════════════
   Slide-out timeline chart panel
   ══════════════════════════════════════ */
#chartpanel{
  position:absolute;top:0;left:0;height:100%;width:380px;max-width:88vw;
  background:#FDF6E3;border-left:3px solid var(--gold-dk);
  box-shadow:6px 0 24px rgba(0,0,0,.4);
  z-index:600;
  transform:translateX(-100%);
  transition:transform .32s cubic-bezier(.22,.61,.36,1);
  display:flex;flex-direction:column;
  direction:rtl;
}
#chartpanel.open{transform:translateX(0)}
#chartpanel-hdr{
  padding:14px 18px 12px;border-bottom:2px solid rgba(200,134,10,.3);
  display:flex;justify-content:space-between;align-items:center;flex-shrink:0;
  background:#1A1208;
}
#chartpanel-hdr h3{color:var(--gold);font-size:17px;font-weight:900}
#chartclose{
  background:rgba(255,255,255,.08);border:none;cursor:pointer;font-size:17px;
  color:#C8B890;padding:4px 11px;border-radius:50%;line-height:1;
}
#chartclose:hover{background:rgba(255,255,255,.18);color:#fff}
#chartscroll{flex:1;overflow-y:auto;padding:14px 16px 30px}

.chart-period-label{
  font-size:13px;font-weight:900;letter-spacing:1px;margin:18px 0 8px;
  padding:4px 0;border-bottom:2px solid;
}
.chart-period-label.tan{color:var(--gold-dk);border-color:var(--gold-dk)}
.chart-period-label.amo{color:var(--blue-dk);border-color:var(--blue-dk)}

.chart-gen{
  margin-bottom:10px;border-radius:10px;overflow:hidden;
  border:1.5px solid rgba(0,0,0,.08);background:#fff;
}
.chart-gen-hdr{
  padding:7px 12px;font-size:12.5px;font-weight:800;
  display:flex;justify-content:space-between;align-items:center;
}
.chart-gen-hdr.tan{background:var(--gold-pale);color:var(--gold-dk)}
.chart-gen-hdr.amo{background:var(--blue-pale);color:var(--blue-dk)}
.chart-gen-years{font-size:10.5px;font-weight:600;opacity:.75;font-family:sans-serif}

.chart-rabbi{
  padding:7px 12px;font-size:13.5px;color:var(--ink);cursor:pointer;
  border-top:1px solid rgba(0,0,0,.06);
  display:flex;justify-content:space-between;align-items:center;gap:8px;
  transition:background .15s;
}
.chart-rabbi:hover{background:rgba(200,134,10,.1)}
.chart-rabbi-name{font-weight:700}
.chart-rabbi-years{font-size:10.5px;color:#8A7A60;font-family:sans-serif;white-space:nowrap}

.chart-rabbi.highlight{
  background:linear-gradient(90deg, rgba(255,215,0,.35), rgba(255,215,0,.12));
  box-shadow:inset 3px 0 0 #FFD700;
  animation:chartFlash 1.1s ease 2;
}
@keyframes chartFlash{
  0%,100%{background-color:rgba(255,215,0,.35)}
  50%{background-color:rgba(255,215,0,.65)}
}

/* Persistent selection (daf mode): stays highlighted until a different
   sage is clicked, unlike .highlight which is a brief flash. */
.chart-rabbi.selected{
  background:rgba(255,215,0,.28) !important;
  box-shadow:inset 3px 0 0 #FFD700;
}

/* ══════════════════════════════════════
   Print-only stylesheet for the reference chart PDF
   ══════════════════════════════════════ */
#printchart{display:none}
@media print{
  body *{visibility:hidden}
  #printchart, #printchart *{visibility:visible}
  #printchart{
    display:block !important;
    position:absolute;top:0;left:0;width:100%;
    direction:rtl;font-family:'Noto Serif Hebrew',serif;color:#000;
    background:#fff;
  }
  @page{size:A4 landscape;margin:8mm}
  #printchart h1{font-size:20px;text-align:center;margin-bottom:2mm;font-weight:900}
  #printchart .print-sub{text-align:center;font-size:10px;color:#555;margin-bottom:4mm}
  #printchart .print-cols{display:flex;gap:6mm}
  #printchart .print-col{flex:1;min-width:0}
  #printchart .print-period{
    font-size:12px;font-weight:900;border-bottom:1.5px solid #000;
    padding-bottom:1mm;margin-bottom:2mm;
  }
  #printchart .print-gen{margin-bottom:2.2mm;break-inside:avoid}
  #printchart .print-gen-hdr{
    font-size:9.5px;font-weight:800;background:#eee;padding:1mm 2mm;
    display:flex;justify-content:space-between;border:0.5px solid #999;
  }
  #printchart .print-rabbi{
    font-size:8.3px;padding:0.7mm 2mm;border-bottom:0.3px solid #ddd;
    display:flex;justify-content:space-between;gap:2mm;
  }
  #printchart .print-rabbi-name{font-weight:700}
  #printchart .print-rabbi-years{color:#555;white-space:nowrap}
  #printchart .print-rabbi-role{color:#777;font-size:7.6px}
}
</style>
</head>
<body>
<div id="app">

<div id="hdr">
  <div>
    <div id="htitle">🗺️ מפת התנאים והאמוראים — OpenStreetMap</div>
    <div id="hsub">הזז את הסליידר · לחץ על סמל לפרטים · גרור לזוז · גלגל/כפתורים לזום</div>
  </div>
  <div class="lpills">
    <div class="lpill"><div class="ldot" style="background:#C8860A"></div>תנאים</div>
    <div class="lpill"><div class="ldot" style="background:#2563EB"></div>אמוראים</div>
    <div class="lpill"><div class="ldot" style="background:#FFD700;border:1.5px solid #aaa"></div>נשיא/ראש ישיבה</div>
    <button id="chartbtn" title="הצג/הסתר ציר זמן">📜 ציר זמן</button>
    <button id="printbtn" title="הדפס דף ייחוס PDF">🖨️ הדפס טבלה</button>
  </div>
</div>

<div id="tpanel">
  <div id="ttop">
    <div><div id="ydisplay">50</div><div id="ylabel">לספירה</div></div>
    <button id="playbtn">▶</button>
    <div id="cbadge">0 חכמים</div>
    <div id="plabel"></div>
  </div>
  <div id="ttrack">
    <div id="pbars">
      <div class="pbar tan" style="left:0;width:43.9%">תנאים</div>
      <div class="pbar amo" style="left:43.9%;right:0">אמוראים</div>
    </div>
    <div id="swrap"><div id="sbg"></div><div id="sfill"></div><input type="range" id="slider" min="10" max="500" value="50" step="1"></div>
    <div id="yticks"></div>
  </div>
</div>

<div id="dafpanel">
  <span id="dafpanel-label">📖 מסכת חולין:</span>
  <select id="dafselect">
    <option value="">— בחר עמוד —</option>
  </select>
  <span id="dafverified" style="display:none">✓ מאומת — חכמים אמיתיים מהדף</span>
  <span id="dafunverified" style="display:none">⚠️ עדיין לא אומת — אין עדיין רשימת חכמים אמיתית לעמוד זה</span>
  <button id="dafclear" style="display:none">✕ נקה בחירה</button>
  <div id="gen-legend"></div>
</div>

<div id="mapwrap">
  <div id="map"></div>
  <div id="chartpanel">
    <div id="chartpanel-hdr">
      <button id="chartclose">✕</button>
      <h3>📜 ציר זמן — תנאים ואמוראים</h3>
    </div>
    <div id="chartscroll"></div>
  </div>
</div>

<div id="info">
  <div id="ihdr">
    <div><div id="iname"></div><div id="ibadge"></div></div>
    <button id="iclose">✕</button>
  </div>
  <div id="ibody">
    <div class="irow">
      <div class="ifield"><div class="ilbl">שנות חיים</div><div class="ival" id="iyears"></div></div>
      <div class="ifield"><div class="ilbl">תפקיד</div><div class="ival" id="irole"></div></div>
    </div>
    <div id="icity">📍 <span id="icitytxt"></span></div>
    <div id="idesc"></div>
  </div>
</div>

</div><!-- #app -->

<!-- Hidden print-only reference table, populated by JS, shown only when printing -->
<div id="printchart"></div>

<script>
const RABBIS=[
  {id:"hillel",       name:"הלל הזקן",           type:"tan",gen:"דור א׳",born:null,died:null, lat:31.776,lng:35.234,city:"ירושלים",        role:"ראש בית הלל",           isL:false,desc:"מגדולי חכמי ישראל, מייסד בית הלל. נולד בבבל ועלה לארץ ישראל. 'מה דסני עלך לחברך לא תעביד — זו כל התורה כולה'."},
